.agent-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 消息列表 */
.chat-list {
  flex: 1;
  padding: 20rpx 24rpx;
}

/* 欢迎区域 */
.welcome-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}
.welcome-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(233, 95, 60, 0.15);
}
.welcome-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #20232a;
  margin-bottom: 8rpx;
}
.welcome-desc {
  font-size: 26rpx;
  color: #999;
}

/* 消息行 */
.msg-row {
  display: flex;
  margin-bottom: 32rpx;
}
.msg-left {
  flex-direction: row;
}
.msg-right {
  flex-direction: row-reverse;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  margin: 0 12rpx;
}
.avatar-user {
  background: #ffc200;
  padding: 8rpx;
  box-sizing: border-box;
}
.bubble-wrap {
  max-width: 75%;
}
.bubble {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 42rpx;
  word-break: break-all;
}
.bubble-ai {
  background: #fff;
  color: #333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.bubble-user {
  background: #E95F3C;
  color: #fff;
  border-top-right-radius: 4rpx;
}
.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 8rpx;
  padding: 0 4rpx;
}

/* 加载动画 */
.loading-dots {
  padding: 16rpx 32rpx;
}
.dot {
  font-size: 16rpx;
  color: #ccc;
  margin: 0 4rpx;
  animation: blink 1.4s infinite both;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; }
  40% { opacity: 1; }
}

/* 快捷操作 */
.quick-actions {
  padding: 20rpx 24rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}
.qa-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.qa-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.qa-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fef5f0;
  border: 1rpx solid #fdd;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #E95F3C;
}
.qa-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}
.qa-text {
  font-weight: 500;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  gap: 16rpx;
}
.input-box {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #333;
}
.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #E95F3C;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  border: none;
  padding: 0;
}
.send-btn[disabled] {
  background: #ddd;
  color: #999;
}
