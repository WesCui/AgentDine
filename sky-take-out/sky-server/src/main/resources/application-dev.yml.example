# ============================================================
# 苍穹外卖 — 开发环境配置模板
# 使用方式：复制为 application-dev.yml 并填入真实值
#   cp application-dev.yml.example application-dev.yml
# ============================================================

sky:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    host: localhost
    port: 3306
    database: sky_take_out
    username: root
    password: ${MYSQL_PASSWORD}           # 替换为真实密码
  redis:
    host: localhost
    port: 6379
    password: ${REDIS_PASSWORD}            # 替换为真实密码
  alioss:
    endpoint: ${ALIOSS_ENDPOINT}           # oss-cn-xxxxx.aliyuncs.com
    access-key-id: ${ALIOSS_ACCESS_KEY_ID}
    access-key-secret: ${ALIOSS_ACCESS_KEY_SECRET}
    bucket-name: ${ALIOSS_BUCKET_NAME}
  wechat:
    appid: ${WECHAT_APPID}
    secret: ${WECHAT_SECRET}
    mchid: ${WECHAT_MCHID}
    mchSerialNo: ${WECHAT_MCH_SERIAL_NO}
    privateKeyFilePath: ${WECHAT_PRIVATE_KEY_PATH}
    apiV3Key: ${WECHAT_API_V3_KEY}
    weChatPayCertFilePath: ${WECHAT_PAY_CERT_PATH}
    notifyUrl: ${WECHAT_NOTIFY_URL}
    refundNotifyUrl: ${WECHAT_REFUND_NOTIFY_URL}

langchain4j:
  open-ai:
    chat-model:
      api-key: ${OPENAI_API_KEY}           # OpenAI / DeepSeek / 通义千问
      model-name: gpt-3.5-turbo
      log-requests: true
      log-responses: true

spring:
  config:
    import:
      - classpath:application-agent.yml
